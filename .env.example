# AISStream API key — get one at https://aisstream.io
AIS_API_KEY=your_aisstream_api_key_here

# AWS S3 bucket name (must already exist)
S3_BUCKET=your-s3-bucket-name

# AWS region where the bucket lives
AWS_REGION=us-east-1

# S3 key prefix for raw AIS files (sub-folder inside the bucket)
S3_PREFIX=raw/ais

# Number of AIS records to accumulate before flushing to S3
BATCH_SIZE=500

# Maximum seconds between flushes (even if batch_size is not reached)
FLUSH_INTERVAL_SEC=60

# Seconds to wait before reconnecting after a WebSocket error
RECONNECT_DELAY_SEC=5

# AISStream WebSocket endpoint (rarely needs changing)
# AIS_WS_URL=wss://stream.aisstream.io/v0/stream
